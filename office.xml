<project name="office_mngt" default="run" basedir="." xmlns:sonar="antlib:org.sonar.ant">

	<property file="build.properties" />

	<property name="sonar.host.url" value="http://localhost:9000" />
	<property name="sonar.login" value="squ_2a385f374dc063f8df14cca2a075be392b9132dc" />
	<property name="sonar.projectKey" value="office_management_system" />
	<property name="sonar.projectName" value="Office Management Project" />
	<property name="sonar.projectVersion" value="1.0" />
	<property name="sonar.sources" value="${srcdir}" />
	<property name="sonar.java.binaries" value="${builddir}/${classdir}" />

	<path id="junit.classpath">
		<pathelement path="${builddir}/${classdir}" />
		<fileset dir = "lib">
			<include name="*.jar" />
		</fileset>
	</path>

	<target name="clean">
		<delete dir="${builddir}" />
		<delete dir="${jarddir}" />
		<delete dir="test-reports" />
	</target>
	
	<target name="compile" depends="clean">
		<mkdir dir="${builddir}/${classdir}" />
		<javac srcdir="${srcdir}" destdir="${builddir}/${classdir}" includeantruntime="false" >
			<classpath refid="junit.classpath" />
		</javac>
	</target>

	<target name="sonar" depends="compile">
		<taskdef uri="antlib:org.sonar.ant" resource="org/sonar/ant/antlib.xml">
			<classpath>
				<fileset dir="lib" includes="sonarqube-ant-task-*.jar" />
			</classpath>
		</taskdef>
		<sonar:sonar/>
	</target>

	<target name="test" depends="compile">
		<mkdir dir="test-reports" />
		<junit printsummary="yes" haltonfailure="yes" >
			<classpath refid="junit.classpath" />
			<formatter type="plain" />
			<batchtest todir="test-reports">
				<fileset dir="${srcdir}">
					<include name="**/*Test.java" />
				</fileset>
			</batchtest>
		</junit>
	</target>

	<target name="run" depends="compile">
		<java classname="OfficeManager" fork="true">
			<classpath>
				<pathelement path="${builddir}/${classdir}" />
			</classpath>
		</java>
	</target>
</project>